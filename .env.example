# Django Configuration
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False
DOMAIN=yourdomain.pythonanywhere.com
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.pythonanywhere.com

# Database Configuration
DB_NAME=freelance_platform
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=db
DB_PORT=5432

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@pro4me.co.za

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# WhatsApp Configuration
WHATSAPP_PROVIDER=360dialog
WHATSAPP_API_KEY=your-360dialog-api-key
WHATSAPP_PHONE_NUMBER=+1234567890
WHATSAPP_WEBHOOK_URL=https://yourdomain.pythonanywhere.com/webhook/whatsapp/

# Twilio Configuration (Legacy)
TWILIO_ENABLED=False
TWILIO_WHATSAPP_ENABLED=False
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Social Media
GOOGLE_OAUTH2_KEY=your-google-oauth2-key
GOOGLE_OAUTH2_SECRET=your-google-oauth2-secret
